acme.validation.header.message  	= Debe tener entre 1 y 75 caracteres.
acme.validation.text.message   		= Debe tener entre 1 y 255 caracteres.
acme.validation.ticker.message			  = La referencia debe seguir este formato ^[A-Z]{2}\\d{2}-\\w{5,10}$

# campaigns
acme.validation.campaign.duplicated-ticker.message = La referencia está duplicada
acme.validation.campaign.no-milestones.message = Una campaña publicada debe tener al menos un hito
acme.validation.campaign.invalid-date-interval.message = El momento final debe ser posterior al momento inicial.
acme.validation.campaign.invalid-future-date-interval.message = Momento inicio/momento fin debe ser un intervalo de tiempo válido en el futuro.

# sponsorship
acme.validation.sponsorship.duplicated-ticker.message = La referencia está duplicada
acme.validation.sponsorship.end-after-start = El momento de fin debe ser posterior al momento de inicio.
acme.validation.sponsorship.at-least-one-donation = No hay donaciones asociadas a este patrocinio
acme.validation.sponsorship.published-future = Para ser publicado debe estar el intervalo de tiempo en un periodo en el futuro.
acme.validation.sponsorship.eur-currency.message = Solo se aceptan euros.

# auditReport
acme.validation.audit-report.ticker.unique.message = Este ticker ya se encuentra registrado en otro informe de auditoría
acme.validation.auditReport.auditSections.error.message = Para que un informe pueda ser publicado, debe contener como mínimo una sección
acme.validation.audit-report.start-before-end.message = El periodo entre el inicio y el fin debe ser coherente y situarse íntegramente en el futuro
acme.validation.auditReport.startMoment.future = La fecha de inicio debe ser posterior al momento actual
acme.validation.auditReport.endMoment.future = La fecha de finalización tiene que estar situada en un momento futuro
acme.validation.audit-report.published-without-audit-section.message = Es obligatorio añadir al menos una sección de auditoría antes de realizar la publicación